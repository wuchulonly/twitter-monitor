# 数据库路径
DATABASE_URL=sqlite+aiosqlite:///./data/twitter_monitor.db

# Cookie 加密密钥 (自动生成，首次运行时创建)
SECRET_KEY=your-secret-key-change-this

# 默认检查间隔（分钟）
DEFAULT_CHECK_INTERVAL=5

# 企业微信 Webhook Key
WECHAT_WEBHOOK_KEY=

# Server酱 SendKey
SERVERCHAN_SENDKEY=

# Twitter/X 出站代理（填本机 Clash/Mihomo 暴露出来的代理端口，不是订阅链接）
# 例如: http://127.0.0.1:7890 或 socks5://127.0.0.1:7891
TWITTER_PROXY_URL=
TWITTER_PROXY_TIMEOUT=45
TWITTER_TRANSACTION_FALLBACK=true
